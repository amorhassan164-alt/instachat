# ── Instagram / Facebook ────────────────────────────────────────────────────
# Long-lived User Access Token from Graph API Explorer (expires in 60 days)
INSTAGRAM_ACCESS_TOKEN=

# Your Facebook Page ID (numeric, found in Page About section)
FACEBOOK_PAGE_ID=

# Instagram Business Account ID
# Get it: GET /{page-id}?fields=instagram_business_account&access_token=...
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Your Facebook App's App Secret (found in App Dashboard > Settings > Basic)
FACEBOOK_APP_SECRET=

# ── Webhook ──────────────────────────────────────────────────────────────────
# A random string you choose — must match what you enter in Facebook webhook config
WEBHOOK_VERIFY_TOKEN=my_secret_verify_token_change_me

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default) — change to postgres://user:pass@host/db for production
DATABASE_URL=sqlite:///./app.db
